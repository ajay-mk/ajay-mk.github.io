---
import { site, nav } from '../config';
import ThemeToggle from './ThemeToggle.astro';
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
const tab = (href: string) => (href === '/' ? '~/home' : `~${href}`);
---

<div class="titlebar">
  <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
  <span class="title"><b>~/{site.brand}</b> — zsh — <span id="winsize">80×24</span></span>
  <ThemeToggle />
</div>
<nav class="tabs">
  {nav.map((item) => (
    <a class={isActive(item.href) ? 'active' : ''} href={item.href}>{tab(item.href)}</a>
  ))}
</nav>

<style>
  .titlebar :global(#theme-toggle) {
    margin-left: 8px; font-size: 0.8rem; line-height: 1; padding: 3px 7px;
    background: none; border: 1px solid var(--border); color: var(--text-muted);
    border-radius: 5px; cursor: pointer;
  }
  .titlebar :global(#theme-toggle:hover) { color: var(--accent); border-color: var(--accent); }
</style>
