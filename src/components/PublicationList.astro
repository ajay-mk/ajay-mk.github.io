---
import type { Publication } from '../lib/publications';
import { site } from '../config';
interface Props { items: Publication[]; start?: number; }
const { items, start = 0 } = Astro.props;

// emphasize the owner's surname in author lists
const lastName = site.name.split(' ').slice(-1)[0];
const emphasize = (author: string) => author.includes(lastName);
---

<div class="pubs">
  {items.map((p, i) => (
    <div class="pub">
      <span class="yr">[{start + i + 1}]</span>
      <div>
        <div class="ti">{p.title}</div>
        <div class="au">
          {p.authors.map((a, idx) => (
            <>{idx > 0 ? ', ' : ''}<span class={emphasize(a) ? 'me' : ''}>{a}</span></>
          ))}
        </div>
        {p.venue && <div class="vn">{p.venue}</div>}
        {p.doi && <a class="doi" href={p.url ?? `https://doi.org/${p.doi}`}>doi:{p.doi}</a>}
      </div>
    </div>
  ))}
</div>
