---
import { site } from '../config';
const year = new Date().getFullYear();
---

<footer>
  <ul>
    <li><a href={site.socials.github}>github</a></li>
    <li><a href={site.socials.scholar}>scholar</a></li>
    <li><a href={site.socials.orcid}>orcid</a></li>
    <li><a href={site.socials.instagram}>instagram</a></li>
    {site.email && <li><a href={`mailto:${site.email}`}>email</a></li>}
  </ul>
  <p class="mono">© {year} {site.name}</p>
</footer>

<style>
  footer { border-top: 1px solid var(--border); padding: 28px 0; display: flex; align-items: center; gap: 18px; }
  ul { list-style: none; display: flex; gap: 18px; }
  ul a { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-muted); }
  ul a:hover { color: var(--accent); }
  p { margin-left: auto; color: var(--text-muted); font-size: 0.8rem; }
</style>
