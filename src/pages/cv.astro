---
import Base from '../layouts/Base.astro';
import Prompt from '../components/Prompt.astro';
import { site } from '../config';
import { getCollection } from 'astro:content';

const order = ['education', 'experience', 'talks', 'skills'];
const entries = await getCollection('cv');
const sections = order
  .map((id) => entries.find((e) => e.id === id)?.data)
  .filter((d): d is NonNullable<typeof d> => Boolean(d));
const isSkills = (id: string) => id === 'skills';
---
<Base title="cv">
  <p class="ln"><span class="prompt"><span class="u">~/{site.brand}</span> $</span> <span class="cmd">cat cv.md</span> <span class="flag"># </span><a href="/cv/Ajay_CV.pdf">download PDF ↗</a></p>

  {sections.map((s) => (
    <section>
      <p class="yr-head"># {s.section}</p>
      {isSkills(s.section)
        ? <div class="tags">{s.items.flatMap((i) => i.details ?? []).map((d) => <span>{d}</span>)}</div>
        : s.items.map((it) => (
            <div class="cv-item">
              <div class="ro" set:html={it.role} />
              {it.org && <div class="or" set:html={it.org} />}
              {it.when && <div class="wn">{it.when}</div>}
              {it.details && <ul>{it.details.map((d) => <li set:html={d} />)}</ul>}
            </div>
          ))}
    </section>
  ))}

  <div class="spacer"></div>
  <p class="ln"><span class="prompt"><span class="u">~/{site.brand}</span> $</span> <span class="cursor"></span></p>
</Base>
