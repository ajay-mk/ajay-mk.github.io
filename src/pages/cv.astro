---
import Base from '../layouts/Base.astro';
import Prompt from '../components/Prompt.astro';
import { getCollection } from 'astro:content';

const order = ['education', 'experience', 'skills'];
const entries = await getCollection('cv');
const sections = order
  .map((id) => entries.find((e) => e.id === id)?.data)
  .filter((d): d is NonNullable<typeof d> => Boolean(d));
const isSkills = (id: string) => id === 'skills';
---
<Base title="cv">
  <Prompt cmd="cat cv.md" />
  <div class="cv-head">
    <h1 class="page-title">curriculum vitae</h1>
    <a class="pdf mono" href="/cv/Ajay_CV.pdf">download PDF ↗</a>
  </div>

  {sections.map((s) => (
    <section>
      <h2 class="section-marker">## {s.section}</h2>
      {isSkills(s.section)
        ? <div class="skills">{s.items.flatMap((i) => i.details ?? []).map((d) => <span class="tag">{d}</span>)}</div>
        : <div class="timeline">
            {s.items.map((it) => (
              <div class="item">
                <div class="role">{it.role}</div>
                {it.org && <div class="org">{it.org}</div>}
                {it.when && <div class="when mono">{it.when}</div>}
                {it.details && <ul>{it.details.map((d) => <li>{d}</li>)}</ul>}
              </div>
            ))}
          </div>}
    </section>
  ))}
</Base>

<style>
  .cv-head { display: flex; justify-content: space-between; align-items: baseline; gap: 16px; }
  .cv-head .page-title { margin-bottom: 32px; }
  .pdf { font-size: 0.9rem; white-space: nowrap; }
  .skills { display: flex; gap: 8px; flex-wrap: wrap; }
  .timeline { display: flex; flex-direction: column; gap: 4px; }
  .item { border-left: 2px solid var(--border); padding: 10px 0 10px 18px; position: relative; }
  .item::before { content: ''; position: absolute; left: -6px; top: 16px; width: 10px; height: 10px; border-radius: 50%; background: var(--accent); }
  .role { color: var(--text-strong); font-weight: 600; }
  .org { color: var(--text-muted); font-size: 0.92rem; margin-top: 2px; }
  .when { color: var(--text-muted); font-size: 0.8rem; margin-top: 2px; }
  .item ul { margin: 8px 0 0 18px; color: var(--text); font-size: 0.92rem; }
</style>
