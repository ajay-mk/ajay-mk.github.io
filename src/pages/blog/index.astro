---
import Base from '../../layouts/Base.astro';
import Prompt from '../../components/Prompt.astro';
import { site } from '../../config';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = (d: Date) => d.toISOString().slice(0, 10);
---
<Base title="blog">
  <Prompt cmd="ls blog/" flag="--sort=date" />
  {posts.length === 0 ? <p class="ln">No posts yet.</p> : (
    <div class="entries">
      {posts.map((p) => (
        <div class="entry">
          <a class="ti" href={`/blog/${p.id}/`}>{p.data.title}</a>
          <div class="em">{fmt(p.data.date)} · {p.data.tags.join(', ')}</div>
          <p class="de">{p.data.description}</p>
        </div>
      ))}
    </div>
  )}
  <div class="spacer"></div>
  <p class="ln"><span class="prompt"><span class="u">~/{site.brand}</span> $</span> <span class="cursor"></span></p>
</Base>

<style>
  .entry { padding: 16px 0; border-bottom: 1px solid var(--border); }
  .entry .ti { color: var(--text-strong); font-size: 1.05rem; }
  .entry .ti:hover { color: var(--accent); }
  .entry .em { color: var(--text-muted); font-size: 0.8rem; margin-top: 4px; }
  .entry .de { color: var(--text-muted); margin-top: 6px; }
</style>
