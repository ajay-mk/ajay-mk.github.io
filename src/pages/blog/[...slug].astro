---
import Base from '../../layouts/Base.astro';
import Prompt from '../../components/Prompt.astro';
import { site } from '../../config';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) => d.toISOString().slice(0, 10);
---
<Base title={post.data.title} description={post.data.description}>
  <Prompt cmd={`cat ${post.id}.md`} />
  <article>
    <h1 class="post-title">{post.data.title}</h1>
    <p class="meta">{fmt(post.data.date)} · {post.data.tags.join(', ')}</p>
    <div class="prose"><Content /></div>
  </article>
  <div class="spacer"></div>
  <p class="ln"><span class="prompt"><span class="u">~/{site.brand}</span> $</span> <span class="cursor"></span></p>
</Base>

<style>
  .post-title { color: var(--text-strong); font-size: 1.4rem; margin: 14px 0 4px; }
  .meta { color: var(--text-muted); font-size: 0.85rem; margin: 0 0 22px; }
  .prose :global(p) { margin: 0 0 16px; }
  .prose :global(h2) { font-family: var(--font-mono); color: var(--accent); margin: 28px 0 12px; }
  .prose :global(pre) { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 14px; overflow-x: auto; margin: 0 0 16px; }
  .prose :global(code) { font-family: var(--font-mono); font-size: 0.88rem; }
</style>
